class Solution:
    def trap(self, height: List[int]) -> int:
        n=len(height)
        left,right=0,n-1
        lmax=rmax=0
        water=0
        while left<right:
            if height[left]<height[right]:
                if height[left]>=lmax:
                    lmax=height[left]
                else:
                    water+=lmax-height[left]
                left+=1
            else:
                if height[right]>=rmax:
                    rmax=height[right]
                else:
                    water+=rmax-height[right]
                right-=1
        return water
